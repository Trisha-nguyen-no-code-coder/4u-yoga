<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Khoá Thiền 21 Ngày · Thử Thách Đón Hạnh Phúc · 4U Yoga</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet"/>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --sage:      #4A6741;
  --sage-mid:  #6B8F62;
  --sage-pale: #C8D9C4;
  --sage-tint: #EEF4EC;
  --gold:      #9C7B3A;
  --gold-pale: #F5EDD8;
  --ink:       #1C1C1A;
  --ink-mid:   #3D3D39;
  --muted:     #7A7A74;
  --border:    #DDDDD6;
  --bg:        #F8F5EF;
  --white:     #FDFCF9;
  --serif:     'Cormorant Garamond', Georgia, serif;
  --sans:      'DM Sans', system-ui, sans-serif;
  --r:         12px;
  --rsm:       8px;
}

html { font-size: 16px; }
body {
  font-family: var(--sans);
  background: var(--bg);
  color: var(--ink);
  min-height: 100vh;
  display: flex;
  justify-content: center;
}

.shell {
  width: 100%;
  max-width: 640px;
  min-height: 100vh;
  background: var(--white);
  position: relative;
}

/* PROGRESS */
.prog-track {
  position: fixed; top: 0; left: 50%;
  transform: translateX(-50%);
  width: 100%; max-width: 640px;
  height: 3px; background: var(--border); z-index: 100;
}
.prog-fill {
  height: 100%; background: var(--sage);
  transition: width 0.55s cubic-bezier(.4,0,.2,1);
}

/* TOP BAR */
.top-bar {
  position: fixed; top: 3px; left: 50%;
  transform: translateX(-50%);
  width: 100%; max-width: 640px;
  padding: 13px 22px;
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(253,252,249,0.96);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--border);
  z-index: 99;
}
.brand-mark {
  font-family: var(--serif);
  font-size: 14px; font-weight: 500;
  color: var(--sage); letter-spacing: 0.05em;
}
.step-counter {
  font-size: 11px; color: var(--muted);
  font-weight: 400; letter-spacing: 0.07em;
}

/* STEPS */
.content { padding-top: 64px; }
.step {
  display: none; flex-direction: column;
  padding: 2rem 1.75rem 7rem;
  animation: rise 0.4s cubic-bezier(.4,0,.2,1) both;
  min-height: calc(100vh - 64px);
}
.step.active { display: flex; }
@keyframes rise {
  from { opacity:0; transform:translateY(16px); }
  to   { opacity:1; transform:translateY(0); }
}

/* LABELS */
.kicker {
  font-size: 11px; font-weight: 500;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--sage); margin-bottom: 0.55rem;
}
.q-head {
  font-family: var(--serif);
  font-size: 27px; font-weight: 500;
  line-height: 1.25; color: var(--ink);
  margin-bottom: 0.55rem;
}
.q-head em { font-style: italic; color: var(--sage); }
.q-sub {
  font-size: 14px; color: var(--muted);
  line-height: 1.65; font-weight: 300;
  margin-bottom: 1.75rem;
}

/* STAT CARD */
.stat-card {
  display: flex; gap: 14px; align-items: flex-start;
  background: var(--sage-tint);
  border: 1px solid var(--sage-pale);
  border-radius: var(--r);
  padding: 1rem 1.2rem; margin-bottom: 1.5rem;
}
.stat-num {
  font-family: var(--serif);
  font-size: 34px; font-weight: 600;
  color: var(--sage); line-height: 1;
  white-space: nowrap; padding-top: 3px;
}
.stat-text {
  font-size: 13px; color: var(--ink-mid);
  line-height: 1.6; font-weight: 300;
}
.stat-text strong { font-weight: 500; color: var(--sage); }

/* MOTIVATION */
.motiv {
  border-left: 2px solid var(--gold);
  background: var(--gold-pale);
  border-radius: 0 var(--rsm) var(--rsm) 0;
  padding: 0.8rem 1.1rem; margin-bottom: 1.5rem;
}
.motiv p {
  font-family: var(--serif);
  font-size: 15px; font-style: italic;
  color: var(--gold); line-height: 1.65;
}

/* WARN */
.warn {
  background: #FDF3F0; border: 1px solid #EDCBC0;
  border-radius: var(--r);
  padding: 0.9rem 1.1rem; margin-bottom: 1.5rem;
  font-size: 13px; color: #7A3322; line-height: 1.6; font-weight: 300;
}
.warn strong { font-weight: 500; }

/* OUTCOMES CARD */
.outcomes {
  background: var(--sage-tint);
  border: 1px solid var(--sage-pale);
  border-radius: var(--r);
  padding: 1rem 1.2rem; margin-bottom: 1.5rem;
}
.outcomes-title {
  font-size: 11px; font-weight: 500; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--sage);
  margin-bottom: 0.65rem;
}
.outcome-row {
  display: flex; align-items: flex-start; gap: 10px;
  padding: 5px 0;
  border-bottom: 1px solid var(--sage-pale);
  font-size: 13px; color: var(--ink-mid); line-height: 1.5;
}
.outcome-row:last-child { border-bottom: none; }
.outcome-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--sage-mid); flex-shrink: 0; margin-top: 5px;
}

/* OPTIONS */
.opts { display: flex; flex-direction: column; gap: 9px; }
.opt {
  display: flex; align-items: flex-start; gap: 13px;
  padding: 0.85rem 1.05rem;
  border: 1px solid var(--border); border-radius: var(--r);
  cursor: pointer; background: var(--white);
  transition: border-color 0.18s, background 0.18s, transform 0.12s;
  text-align: left; width: 100%;
}
.opt:hover { border-color: var(--sage-pale); background: var(--sage-tint); transform: translateY(-1px); }
.opt.selected { border-color: var(--sage); background: var(--sage-tint); }
.opt.selected .opt-key { background: var(--sage); color: var(--white); border-color: var(--sage); }
.opt-key {
  min-width: 26px; height: 26px; border-radius: var(--rsm);
  border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 500; color: var(--muted);
  transition: all 0.18s; background: var(--bg);
  flex-shrink: 0; margin-top: 1px;
}
.opt-body { display: flex; flex-direction: column; gap: 2px; }
.opt-label { font-size: 15px; color: var(--ink); line-height: 1.4; font-weight: 400; }
.opt-hint  { font-size: 12px; color: var(--muted); font-weight: 300; }

/* SCALE */
.scale-row { display: flex; gap: 7px; margin-bottom: 8px; }
.scale-btn {
  flex: 1; padding: 0.85rem 0;
  border: 1px solid var(--border);
  border-radius: var(--rsm);
  background: var(--white);
  font-family: var(--serif);
  font-size: 20px; font-weight: 600; color: var(--ink-mid);
  cursor: pointer; text-align: center;
  transition: all 0.18s;
}
.scale-btn:hover { border-color: var(--sage-pale); background: var(--sage-tint); }
.scale-btn.selected { background: var(--sage); border-color: var(--sage); color: var(--white); }
.scale-labels {
  display: flex; justify-content: space-between;
  font-size: 11px; color: var(--muted);
  letter-spacing: 0.02em; margin-bottom: 1rem;
}

/* FIELD */
.field {
  width: 100%;
  padding: 0.85rem 1rem;
  border: 1px solid var(--border);
  border-radius: var(--r);
  font-size: 15px; font-family: var(--sans);
  color: var(--ink); background: var(--white);
  resize: none;
  transition: border-color 0.18s;
  line-height: 1.6; font-weight: 300;
}
.field:focus { outline: none; border-color: var(--sage); }
.field::placeholder { color: var(--muted); }

/* NAV */
.nav {
  position: fixed; bottom: 0; left: 50%;
  transform: translateX(-50%);
  width: 100%; max-width: 640px;
  padding: 1rem 1.75rem 1.5rem;
  background: rgba(253,252,249,0.97);
  backdrop-filter: blur(10px);
  border-top: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
  z-index: 90;
}
.btn-back {
  background: none; border: none;
  font-size: 13px; color: var(--muted);
  cursor: pointer; padding: 0.5rem 0;
  display: flex; align-items: center; gap: 5px;
  font-family: var(--sans); font-weight: 400;
  transition: color 0.18s;
}
.btn-back:hover { color: var(--ink); }
.btn-next {
  padding: 0.78rem 1.9rem;
  background: var(--sage); color: var(--white);
  border: none; border-radius: 999px;
  font-size: 14px; font-weight: 500; font-family: var(--sans);
  cursor: pointer; letter-spacing: 0.04em;
  display: flex; align-items: center; gap: 7px;
  transition: background 0.18s, transform 0.12s, opacity 0.18s;
}
.btn-next:hover:not(:disabled) { background: var(--ink); transform: scale(1.015); }
.btn-next:disabled { background: var(--sage-pale); color: var(--sage); cursor: not-allowed; }

/* WELCOME */
.hero-art {
  width: 100%; height: 172px;
  background: linear-gradient(145deg, var(--sage-tint) 0%, var(--gold-pale) 100%);
  border-radius: var(--r); margin-bottom: 2rem;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 8px;
  position: relative; overflow: hidden;
}
.hero-art::before {
  content: '';
  position: absolute; inset: 0;
  background-image: radial-gradient(circle, #4A6741 1px, transparent 1px);
  background-size: 28px 28px;
  opacity: 0.09;
}
.hero-icon { font-family: var(--serif); font-size: 46px; line-height: 1; position: relative; }
.hero-sub-art {
  font-size: 11px; font-weight: 500;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--sage); position: relative;
}
.pill {
  display: inline-flex; align-items: center; gap: 6px;
  background: var(--sage-tint);
  border: 1px solid var(--sage-pale);
  border-radius: 999px; padding: 4px 13px;
  font-size: 12px; color: var(--sage); font-weight: 500;
  letter-spacing: 0.04em; margin-bottom: 0.9rem;
}
.pill-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--sage); }

/* RESULT */
.result-wrap { text-align: center; padding: 2.5rem 0.5rem 1rem; }
.result-big { font-size: 44px; margin-bottom: 0.5rem; line-height: 1; }
.result-title { font-family: var(--serif); font-size: 24px; font-weight: 500; color: var(--ink); margin-bottom: 0.65rem; }
.result-badge {
  display: inline-block;
  background: var(--sage-tint); border: 1px solid var(--sage-pale);
  color: var(--sage); border-radius: 999px;
  font-size: 12px; font-weight: 500; padding: 5px 16px;
  margin-bottom: 1.5rem;
}
.result-sub { font-size: 14px; color: var(--muted); line-height: 1.7; font-weight: 300; margin-bottom: 2rem; }
.next-steps {
  text-align: left;
  background: var(--sage-tint);
  border: 1px solid var(--sage-pale);
  border-radius: var(--r);
  padding: 1.1rem 1.4rem; margin: 0 auto 1.75rem;
}
.ns-title {
  font-size: 11px; font-weight: 500; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--sage); margin-bottom: 0.7rem;
}
.ns-row {
  display: flex; align-items: flex-start; gap: 11px;
  padding: 6px 0;
  border-bottom: 1px solid var(--sage-pale);
  font-size: 13px; color: var(--ink-mid); line-height: 1.5; font-weight: 300;
}
.ns-row:last-child { border-bottom: none; }
.ns-num {
  min-width: 22px; height: 22px; border-radius: 50%;
  background: var(--sage); color: white;
  font-size: 11px; font-weight: 500;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; margin-top: 1px;
}
.result-note { font-size: 12px; color: var(--muted); font-style: italic; }

/* DISQUALIFY */
.disq-wrap { text-align: center; padding: 3rem 0.5rem 1rem; }
.disq-icon { font-size: 38px; margin-bottom: 1.25rem; }
.disq-title { font-family: var(--serif); font-size: 23px; font-weight: 500; color: var(--ink); margin-bottom: 0.65rem; }
.disq-sub { font-size: 14px; color: var(--muted); line-height: 1.7; font-weight: 300; max-width: 380px; margin: 0 auto 1.5rem; }
.disq-card {
  background: var(--gold-pale); border: 1px solid #E8D8B0;
  border-radius: var(--r); padding: 1rem 1.2rem;
  margin: 0 auto 1.5rem; max-width: 400px; text-align: left;
}
.disq-card-title { font-size: 11px; font-weight: 500; letter-spacing: 0.09em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.6rem; }
.disq-card p { font-size: 13px; color: #6B5020; line-height: 1.6; font-weight: 300; }
.btn-warm {
  padding: 0.78rem 1.9rem;
  background: var(--gold); color: var(--white);
  border: none; border-radius: 999px;
  font-size: 14px; font-weight: 500; font-family: var(--sans);
  cursor: pointer; letter-spacing: 0.04em;
  transition: background 0.18s;
}
.btn-warm:hover { background: var(--ink); }

@media (max-width: 480px) {
  .step { padding: 1.5rem 1.25rem 7rem; }
  .q-head { font-size: 23px; }
}
</style>
</head>
<body>
<div class="shell">

  <div class="prog-track"><div class="prog-fill" id="prog" style="width:0%"></div></div>

  <div class="top-bar">
    <span class="brand-mark">4U Yoga · Khoá Thiền 21 Ngày</span>
    <span class="step-counter" id="counter"></span>
  </div>

  <div class="content">

    <!-- S0: WELCOME -->
    <div class="step active" id="s0">
      <div class="hero-art" style="background:none;padding:0;height:220px;overflow:hidden;border-radius:var(--r);">
        <img src="data:image/png;base64," alt="Thiền định bình an" style="width:100%;height:100%;object-fit:cover;object-position:center 30%;display:block;border-radius:var(--r);" />
      </div>
      <div class="pill"><span class="pill-dot"></span>K31 · Online qua ZOOM · 05:45 → 06:15</div>
      <div class="q-head">"Hạnh phúc thật sự đang <em>ở đâu?</em>"</div>
      <div class="q-sub">4U Yoga mời Anh / Chị trả lời vài câu hỏi ngắn để xác nhận Khoá Thiền 21 Ngày phù hợp với Hành trình của Anh / Chị · Chỉ mất khoảng 3 phút.</div>
      <div class="stat-card">
        <div class="stat-num">21</div>
        <div class="stat-text">Ngày liên tục · 30 phút mỗi Buổi sáng là đủ để <strong>Tâm trí hình thành Thói quen Kỷ luật mới</strong> — điều mà hầu hết Người chưa bao giờ thực sự thử.</div>
      </div>
      <div class="outcomes">
        <div class="outcomes-title">Học viên đạt được sau Khoá Thiền</div>
        <div class="outcome-row"><span class="outcome-dot"></span><span>Hiểu được "Tôi là Ai" và Bản Ngã là gì</span></div>
        <div class="outcome-row"><span class="outcome-dot"></span><span>Xây dựng Thói quen Kết nối với Bản thân</span></div>
        <div class="outcome-row"><span class="outcome-dot"></span><span>Biết cách tìm thấy Bình an · Tự do · Hạnh phúc</span></div>
        <div class="outcome-row"><span class="outcome-dot"></span><span>Thiết lập Kỷ luật cho Tâm trí</span></div>
      </div>
    </div>

    <!-- S1: TÊN -->
    <div class="step" id="s1">
      <div class="kicker">Câu 1 / 8</div>
      <div class="q-head">4U Yoga muốn gọi <em>tên</em> của Anh / Chị</div>
      <div class="q-sub">Để cá nhân hoá Hành trình trong suốt 21 Ngày Thiền định.</div>
      <input class="field" id="q1" type="text" placeholder="Tên của Anh / Chị…" style="height:52px;" oninput="checkText(1,'q1')"/>
    </div>

    <!-- S2: VẤN ĐỀ SỨC KHOẺ / MỤC TIÊU — aligned với form trên trang -->
    <div class="step" id="s2">
      <div class="kicker">Câu 2 / 8</div>
      <div class="q-head">Anh / Chị đang gặp phải <em>Vấn đề</em> nào trong cuộc sống?</div>
      <div class="q-sub">Chọn điều phản ánh đúng nhất Tình trạng hiện tại của Anh / Chị.</div>
      <div class="opts" id="q2">
        <button class="opt" onclick="selectOpt('q2',this,2)"><span class="opt-key">A</span><div class="opt-body"><span class="opt-label">Tâm trí không nghỉ · Stress và Over thinking kéo dài</span></div></button>
        <button class="opt" onclick="selectOpt('q2',this,2)"><span class="opt-key">B</span><div class="opt-body"><span class="opt-label">Giấc ngủ kém · khó vào giấc hoặc ngủ không sâu</span></div></button>
        <button class="opt" onclick="selectOpt('q2',this,2)"><span class="opt-key">C</span><div class="opt-body"><span class="opt-label">Mất kết nối với Bản thân · cảm thấy trống rỗng, mất phương hướng</span></div></button>
        <button class="opt" onclick="selectOpt('q2',this,2)"><span class="opt-key">D</span><div class="opt-body"><span class="opt-label">Cảm xúc mất kiểm soát · dễ bực bội, lo âu</span></div></button>
        <button class="opt" onclick="selectOpt('q2',this,2)"><span class="opt-key">E</span><div class="opt-body"><span class="opt-label">Thiếu Tập trung · năng suất Công việc giảm sút</span></div></button>
      </div>
    </div>

    <!-- S3: INNER THOUGHT — có biết Khoá này là gì chưa -->
    <div class="step" id="s3">
      <div class="kicker">Câu 3 / 8</div>
      <div class="q-head">"Tôi có thực sự hiểu <em>Thiền</em> là gì không?"</div>
      <div class="motiv">
        <p>Thiền không phải là ngồi yên không nghĩ gì. Thiền là <strong>Phương pháp huấn luyện Tâm trí</strong> — dịch chuyển từ Thói quen Suy nghĩ tiêu cực sang Thói quen mới Hữu ích hơn.</p>
      </div>
      <div class="opts" id="q3">
        <button class="opt" onclick="selectOpt('q3',this,3)"><span class="opt-key">A</span><div class="opt-body"><span class="opt-label">Chưa từng thử · hoàn toàn mới với Thiền định</span></div></button>
        <button class="opt" onclick="selectOpt('q3',this,3)"><span class="opt-key">B</span><div class="opt-body"><span class="opt-label">Đã thử nhưng không duy trì được Thói quen</span></div></button>
        <button class="opt" onclick="selectOpt('q3',this,3)"><span class="opt-key">C</span><div class="opt-body"><span class="opt-label">Thiền không đều đặn · chưa cảm nhận rõ Kết quả</span></div></button>
        <button class="opt" onclick="selectOpt('q3',this,3)"><span class="opt-key">D</span><div class="opt-body"><span class="opt-label">Đã Thiền đều đặn · muốn đi sâu hơn vào Phương pháp</span></div></button>
      </div>
    </div>

    <!-- S4: PHƯƠNG PHÁP SIVANANDA — filter hiểu biết -->
    <div class="step" id="s4">
      <div class="kicker">Câu 4 / 8</div>
      <div class="q-head">Anh / Chị mong muốn điều gì <em>sau 21 Ngày</em>?</div>
      <div style="border-radius:var(--r);overflow:hidden;margin-bottom:1.25rem;height:160px;">
        <img src="data:image/png;base64," alt="Cộng đồng Học viên 4U Yoga" style="width:100%;height:100%;object-fit:cover;object-position:center 20%;display:block;" />
      </div>
      <div class="opts" id="q4">
        <button class="opt" onclick="selectOpt('q4',this,4)"><span class="opt-key">A</span><div class="opt-body"><span class="opt-label">Hiểu được "Tôi là Ai" · tìm lại Bản Ngã và Mục đích Sống</span></div></button>
        <button class="opt" onclick="selectOpt('q4',this,4)"><span class="opt-key">B</span><div class="opt-body"><span class="opt-label">Giảm Stress · cải thiện Giấc ngủ · sống nhẹ nhàng hơn</span></div></button>
        <button class="opt" onclick="selectOpt('q4',this,4)"><span class="opt-key">C</span><div class="opt-body"><span class="opt-label">Thiết lập Kỷ luật Tâm trí · kiểm soát Cảm xúc tốt hơn</span></div></button>
        <button class="opt" onclick="selectOpt('q4',this,4)"><span class="opt-key">D</span><div class="opt-body"><span class="opt-label">Xây dựng Thói quen Tự do · Bình an · Hạnh phúc bền lâu</span></div></button>
      </div>
    </div>

    <!-- S5: CAM KẾT GIỜ — HARD FILTER -->
    <div class="step" id="s5">
      <div class="kicker">Câu 5 / 8 · Quan trọng</div>
      <div class="q-head">Anh / Chị có thể cam kết <em>05:45 mỗi sáng</em> trong 21 ngày liên tục?</div>
      <div class="q-sub">Khoá Thiền diễn ra lúc <strong>05:45 → 06:15</strong> · Online qua ZOOM · <strong>21 Buổi liên tục</strong> · không có Buổi bù.</div>
      <div class="warn"><strong>4U Yoga chia sẻ thẳng:</strong> Kết quả chỉ đến khi Anh / Chị tham gia ĐỦ và ĐỀU. Một buổi bỏ lỡ sẽ làm gián đoạn Hành trình Kỷ luật của Tâm trí. Đây là Thử Thách — không phải Khoá học thông thường.</div>
      <div class="opts" id="q5">
        <button class="opt" onclick="selectOpt('q5',this,5,'yes')"><span class="opt-key">A</span><div class="opt-body"><span class="opt-label">Sẵn sàng · Tôi ưu tiên 05:45 trong 21 ngày</span><span class="opt-hint">Kỷ luật là điều Tôi muốn xây dựng</span></div></button>
        <button class="opt" onclick="selectOpt('q5',this,5,'maybe')"><span class="opt-key">B</span><div class="opt-body"><span class="opt-label">Hầu hết các Buổi · có thể bỏ 1 → 2 buổi do Công việc</span><span class="opt-hint">Sẽ cố gắng tối đa</span></div></button>
        <button class="opt" onclick="selectOpt('q5',this,5,'no')"><span class="opt-key">C</span><div class="opt-body"><span class="opt-label">Chưa chắc · Lịch của Tôi khá bận vào buổi sáng</span><span class="opt-hint">Chưa thể cam kết giờ này</span></div></button>
      </div>
    </div>

    <!-- S6: MỨC ĐỘ CAM KẾT SCALE — MAIN FILTER -->
    <div class="step" id="s6">
      <div class="kicker">Câu 6 / 8 · Đánh giá Cam kết</div>
      <div class="q-head">Mức độ <em>Cam kết và Kỷ luật Bản thân</em> của Anh / Chị hiện tại?</div>
      <div class="stat-card">
        <div class="stat-num">3.4×</div>
        <div class="stat-text">Học viên hoàn thành đủ 21 Buổi có tỷ lệ <strong>duy trì Thói quen Thiền lâu dài cao hơn 3.4 lần</strong> so với Người bỏ dở giữa chừng.</div>
      </div>
      <div class="scale-row" id="q6">
        <button class="scale-btn" onclick="selectScale('q6',this,6,'1')">1</button>
        <button class="scale-btn" onclick="selectScale('q6',this,6,'2')">2</button>
        <button class="scale-btn" onclick="selectScale('q6',this,6,'3')">3</button>
        <button class="scale-btn" onclick="selectScale('q6',this,6,'4')">4</button>
        <button class="scale-btn" onclick="selectScale('q6',this,6,'5')">5</button>
      </div>
      <div class="scale-labels"><span>Tôi cần thêm Thời gian chuẩn bị</span><span>Quyết tâm 100% · Bắt đầu ngay</span></div>
      <div style="border-radius:var(--r);overflow:hidden;margin-bottom:1.25rem;height:160px;">
        <img src="data:image/png;base64," alt="Tự do và Hạnh phúc" style="width:100%;height:100%;object-fit:cover;object-position:center 25%;display:block;" />
      </div>
      <div class="motiv" style="margin-top:0;">
        <p>"Kỷ luật Bản thân không đến từ Động lực nhất thời. Nó đến từ Quyết định ở lại — ngay cả khi không muốn."</p>
      </div>
    </div>

    <!-- S7: KỲ VỌNG MỞ -->
    <div class="step" id="s7">
      <div class="kicker">Câu 7 / 8</div>
      <div class="q-head">Anh / Chị muốn <em>thay đổi điều gì</em> sau Khoá Thiền này?</div>
      <div class="q-sub">Viết bằng lời của chính Anh / Chị · 4U Yoga đọc từng câu trả lời để chuẩn bị tốt nhất cho Khoá học.</div>
      <textarea class="field" id="q7" rows="4" placeholder="Ví dụ: Tôi muốn ngủ ngon hơn và bớt Over thinking. Tôi muốn hiểu vì sao Tôi luôn lo lắng…" oninput="checkText(7,'q7')"></textarea>
    </div>

    <!-- S8: SĐT -->
    <div class="step" id="s8">
      <div class="kicker">Câu 8 / 8 · Bước Cuối</div>
      <div class="q-head">Hẹn gặp Anh / Chị tại <em>Info Session</em></div>
      <div class="q-sub">Để 4U Yoga ghi nhận Kết quả bảng câu hỏi và liên hệ thông tin Info Session, Anh / Chị vui lòng để lại Số Điện thoại.</div>
      <input class="field" id="q8" type="tel" placeholder="Số Điện thoại: 090 123 4567" style="height:52px;" oninput="checkPhone(8,'q8')"/>
    </div>

    <!-- RESULT: PASS -->
    <div class="step" id="sResult">
      <div class="result-wrap">
        <div class="result-big">🌿</div>
        <div class="result-title">Hẹn gặp Anh / Chị tại Info Session!</div>
        <div class="result-badge">4U Yoga đã ghi nhận · K31</div>
        <div class="result-sub">4U Yoga đã nhận được thông tin và Kết quả bảng câu hỏi của Anh / Chị.<br/>Đội ngũ 4U Yoga sẽ liên hệ xác nhận và gửi thông tin Info Session trong vòng 24 giờ.</div>
        <div class="next-steps">
          <div class="ns-title">Hành trình tiếp theo</div>
          <div class="ns-row"><span class="ns-num">1</span><span>4U Yoga liên hệ và gửi thông tin Info Session</span></div>
          <div class="ns-row"><span class="ns-num">2</span><span>Tham gia Info Session · hiểu rõ Khoá Thiền 21 Ngày</span></div>
          <div class="ns-row"><span class="ns-num">3</span><span>Anh / Chị nhận đường dẫn vào Zalo Group K31</span></div>
          <div class="ns-row"><span class="ns-num">4</span><span>Bắt đầu Hành trình 21 Ngày lúc 05:45 🌿</span></div>
        </div>
        <div class="result-note"><em>"Hạnh phúc thật sự đang ở đây — Anh / Chị đã sẵn sàng."</em></div>
      </div>
    </div>

    <!-- RESULT: DISQUALIFY -->
    <div class="step" id="sDisq">
      <div class="disq-wrap">
        <div class="disq-icon">🙏</div>
        <div class="disq-title">Cảm ơn Anh / Chị đã chia sẻ!</div>
        <div class="disq-sub">4U Yoga đã nhận được thông tin và Kết quả bảng câu hỏi của Anh / Chị.</div>
        <div class="disq-card">
          <div class="disq-card-title">Lời nhắn từ 4U Yoga</div>
          <p>4U Yoga rất tiếc khi chưa thể mời Anh / Chị tham gia Khoá Thiền K31 lần này.<br/><br/>Kết quả cho thấy Anh / Chị chưa đủ Cam kết và sẵn sàng cho Hành trình 21 Ngày — trong khi đây là yếu tố cốt lõi để Khoá Thiền mang lại Kết quả thực sự.<br/><br/>4U Yoga sẽ giữ thông tin và đồng hành cùng Anh / Chị khi Anh / Chị đã sẵn sàng hơn.</p>
        </div>
        <button class="btn-warm" onclick="restartForm()">Xem lại câu trả lời</button>
      </div>
    </div>

  </div>

  <!-- FIXED NAV -->
  <div class="nav" id="navBar">
    <button class="btn-back" id="btnBack" onclick="goBack()">
      <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M9 11L5 7L9 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Quay lại
    </button>
    <button class="btn-next" id="btnNext" onclick="goNext()">
      Tiếp tục
      <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M5 3L9 7L5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
  </div>

</div>

<script>
const TOTAL = 8;
let cur = 0;
const ans = {};
const stepIds = ['s0','s1','s2','s3','s4','s5','s6','s7','s8'];

function render() {
  const counter = document.getElementById('counter');
  const btnBack = document.getElementById('btnBack');
  const btnNext = document.getElementById('btnNext');
  const nav = document.getElementById('navBar');

  const isEnd = ['sResult','sDisq'].some(id => document.getElementById(id).classList.contains('active'));
  nav.style.display = isEnd ? 'none' : 'flex';

  const pct = cur === 0 ? 0 : (cur / TOTAL) * 100;
  document.getElementById('prog').style.width = pct + '%';

  if (cur === 0) {
    counter.textContent = '';
    btnBack.style.visibility = 'hidden';
    btnNext.innerHTML = 'Bắt đầu <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M5 3L9 7L5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
    btnNext.disabled = false;
  } else {
    counter.textContent = cur + ' / ' + TOTAL;
    btnBack.style.visibility = 'visible';
    const isLast = cur === TOTAL;
    btnNext.innerHTML = isLast
      ? 'Gửi Đăng ký <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>'
      : 'Tiếp tục <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M5 3L9 7L5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
    btnNext.disabled = !isValid();
  }
}

function isValid() {
  if (cur === 1) return (ans.q1||'').length >= 2;
  if (cur === 2) return !!ans.q2;
  if (cur === 3) return !!ans.q3;
  if (cur === 4) return !!ans.q4;
  if (cur === 5) return !!ans.q5;
  if (cur === 6) return !!ans.q6;
  if (cur === 7) return (ans.q7||'').length >= 4;
  if (cur === 8) return (ans.q8||'').replace(/\D/g,'').length >= 9;
  return true;
}

function show(id) {
  document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0,0);
}

function goNext() {
  if (cur === 0) { cur = 1; show('s1'); render(); return; }
  if (!isValid()) return;
  if (cur === TOTAL) { finish(); return; }
  cur++;
  show(stepIds[cur]);
  render();
}

function goBack() {
  if (cur <= 1) { cur = 0; show('s0'); render(); return; }
  cur--;
  show(stepIds[cur]);
  render();
}

async function finish() {
  const score = parseInt(ans.q6 || '0');
  const timeFlag = ans.q5val;
  const disq = score <= 2 || timeFlag === 'no';

  // Submit to Formspree regardless of result
  try {
    await fetch('https://formspree.io/f/xnjwwvpb', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({
        ten:        ans.q1 || '',
        van_de:     ans.q2 || '',
        kinh_nghiem_thien: ans.q3 || '',
        muc_tieu:   ans.q4 || '',
        cam_ket_gio: ans.q5 || '',
        muc_do_cam_ket: ans.q6 || '',
        ky_vong:    ans.q7 || '',
        so_dien_thoai: ans.q8 || '',
        ket_qua_filter: disq ? 'Chưa phù hợp' : 'Phù hợp · Mời Info Session',
        _subject:   (disq ? '[PENDING] ' : '[PASS] ') + 'Đăng ký Khoá Thiền K31 · ' + (ans.q1 || 'Ẩn danh')
      })
    });
  } catch(e) { console.warn('Formspree error', e); }

  show(disq ? 'sDisq' : 'sResult');
  document.getElementById('prog').style.width = '100%';
  document.getElementById('navBar').style.display = 'none';
}

function restartForm() {
  cur = 0;
  Object.keys(ans).forEach(k => delete ans[k]);
  document.querySelectorAll('.opt').forEach(o => o.classList.remove('selected'));
  document.querySelectorAll('.scale-btn').forEach(b => b.classList.remove('selected'));
  document.querySelectorAll('.field').forEach(f => f.value = '');
  show('s0');
  document.getElementById('navBar').style.display = 'flex';
  render();
}

function selectOpt(qid, el, step, flag) {
  document.getElementById(qid).querySelectorAll('.opt').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  ans[qid] = el.querySelector('.opt-label').textContent;
  if (flag) ans[qid + 'val'] = flag;
  render();
}

function selectScale(qid, el, step, val) {
  document.getElementById(qid).querySelectorAll('.scale-btn').forEach(b => b.classList.remove('selected'));
  el.classList.add('selected');
  ans[qid] = val;
  render();
}

function checkText(step, inputId) {
  ans['q' + step] = document.getElementById(inputId).value.trim();
  render();
}

function checkPhone(step, inputId) {
  ans['q' + step] = document.getElementById(inputId).value.trim();
  render();
}

render();
</script>
</body>
